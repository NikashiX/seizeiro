# Server
BASE_URL="http://localhost:4000"
SECRET_KEY="" # openssl rand -base64 32

# PostgreSQL
POSTGRES_URL="postgres://user:pass@localhost:5432/seizeiro"

# SEI
SEI_BASE_URL=""
# API SOAP legada (SeiWS.php) — necessária apenas para endpoints que usam a
# versão antiga da API (ex.: GET /api/v1/documentos/soap/{protocolo}).
SEI_WS_URL="https://www.sei.mg.gov.br/sei/ws/SeiWS.php"
SEI_SIGLA_SISTEMA=""
SEI_IDENTIFICACAO_SERVICO=""

# Storage de arquivos baixados do SEI.
# Quando STORAGE_AZURE_ACCOUNT está definido, usa Azure Blob Storage e
# devolve URLs assinadas (SAS) com expiração de 1 hora. Caso contrário, usa
# o filesystem local em STORAGE_FILESYSTEM_ROOT e serve via rota interna.
STORAGE_AZURE_ACCOUNT=""
STORAGE_AZURE_KEY=""
STORAGE_AZURE_CONTAINER=""
STORAGE_FILESYSTEM_ROOT=".blob"

# Chatbot webhook (notifica receptor externo quando o cadastro é concluído).
# Quando CHATBOT_WEBHOOK_URL está vazia, nenhuma notificação é disparada.
# CHATBOT_WEBHOOK_SECRET, se definido, é enviado no header `key`.
CHATBOT_WEBHOOK_URL=""
CHATBOT_WEBHOOK_SECRET=""
